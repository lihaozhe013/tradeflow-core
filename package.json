{
  "name": "tradeflow-core",
  "private": true,
  "version": "0.8.4",
  "description": "a lightweight tradeflow system core",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "install:all": "pnpm install && cd frontend && pnpm install && cd ../backend && pnpm install && pnpm prisma generate",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:frontend": "cd frontend && pnpm dev",
    "dev:backend": "cd backend && pnpm dev",
    "build": "uv run build.py",
    "start": "cd dist && cross-env NODE_ENV=production backend/server/.js",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "prettier": "^3.8.1"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
