// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "./client"
}

datasource db {
  provider = "postgresql"
}

// ----------------------------------------------------
// Models mirroring existing tables
// ----------------------------------------------------

model InboundRecord {
  id             Int     @id @default(autoincrement())
  supplier_code  String
  partner        Partner @relation(fields: [supplier_code], references: [code])
  product_code   String?
  product_model  String?
  quantity       Int?
  unit_price     Float?
  total_price    Float?
  inbound_date   String?
  invoice_date   String?
  invoice_number String?
  receipt_number String?
  order_number   String?
  remark         String?

  @@map("inbound_records")
}

model OutboundRecord {
  id             Int     @id @default(autoincrement())
  customer_code  String
  partner        Partner @relation(fields: [customer_code], references: [code])
  product_code   String?
  product_model  String?
  quantity       Int?
  unit_price     Float?
  total_price    Float?
  outbound_date  String?
  invoice_date   String?
  invoice_number String?
  receipt_number String?
  order_number   String?
  remark         String?

  @@map("outbound_records")
}

model Inventory {
  product_model String @id
  quantity      Int    @default(0)

  @@map("inventory")
}

model InventoryLedger {
  id            Int      @id @default(autoincrement())
  product_model String
  change_qty    Int
  change_type   String
  reference_id  Int?
  date          String
  created_at    DateTime @default(now())

  @@map("inventory_ledger")
}

model Partner {
  code            String           @unique
  short_name      String           @id
  full_name       String?
  address         String?
  contact_person  String?
  contact_phone   String?
  type            Int?
  inboundRecords  InboundRecord[]
  outboundRecords OutboundRecord[]

  @@map("partners")
}

model Product {
  code          String  @unique
  category      String?
  product_model String?
  remark        String?

  @@map("products")
}

model ProductPrice {
  id                 Int     @id @default(autoincrement())
  partner_short_name String?
  product_model      String?
  effective_date     String?
  unit_price         Float?

  @@map("product_prices")
}

model User {
  username             String   @id
  password_hash        String
  role                 String
  display_name         String?
  enabled              Boolean  @default(true)
  last_password_change String?
  created_at           DateTime @default(now())

  @@map("users")
}

model ReceivablePayment {
  id            Int     @id @default(autoincrement())
  customer_code String?
  amount        Float?
  pay_date      String?
  pay_method    String?
  remark        String?

  @@map("receivable_payments")
}

model PayablePayment {
  id            Int     @id @default(autoincrement())
  supplier_code String?
  amount        Float?
  pay_date      String?
  pay_method    String?
  remark        String?

  @@map("payable_payments")
}
model SystemLog {
  id          Int      @id @default(autoincrement())
  username    String?
  action      String
  resource    String
  user_agent  String?
  params      String?
  created_at  DateTime @default(now())

  @@map("system_logs")
}
